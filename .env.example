# ── Datacenter Proxy (Tier 3) ─────────────────────────────────────────────────
# Oxylabs Web Unblocker: host=unblock.oxylabs.io, protocol=https, port=60000
DC_PROXY_HOST=unblock.oxylabs.io
DC_PROXY_PORT=60000
DC_PROXY_PROTOCOL=https
DC_PROXY_USERNAME=
DC_PROXY_PASSWORD=
# Default geo (leave blank — auto-geo detection tries CA/GB/AU/SE/IN/US per site)
DC_PROXY_GEO=

# ── Residential Proxy (Tier 4) ────────────────────────────────────────────────
RES_PROXY_HOST=
RES_PROXY_PORT=
RES_PROXY_USERNAME=
RES_PROXY_PASSWORD=
RES_PROXY_GEO_COUNTRIES=US,UK,CA,AU,NZ

# ── Google Drive (direct upload) ──────────────────────────────────────────────
# Option A: OAuth2 user credentials (recommended — works with personal Google Drive)
# Run: node scripts/get-drive-token.js   to obtain these values.
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=
GOOGLE_OAUTH2_REFRESH_TOKEN=
# Option B: Service Account (only works with Shared Drives / Google Workspace)
#   base64 -i your-key.json | tr -d '\n'   (Linux/Mac)
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes('key.json'))  (PowerShell)
GOOGLE_SERVICE_ACCOUNT_KEY=
# Root BannerBot folder ID (copy from URL: drive.google.com/drive/folders/THIS_PART)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── WhatsApp (Meta Business Cloud API) ────────────────────────────────────────
# From Meta Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Your WhatsApp number in E.164 format: +63912345678
WHATSAPP_RECIPIENT=

# ── Backend public URL (Cloud Run) ────────────────────────────────────────────
# Set this to your Cloud Run service URL so the n8n payload includes downloadable
# image URLs. Find it in Cloud Run console after first deploy.
# Example: https://banner-scraper-abc123-uc.a.run.app
BACKEND_URL=https://YOUR-SERVICE-abc123-uc.a.run.app

# ── Anthropic API (for per-section prompt regeneration in the UI) ─────────────
ANTHROPIC_API_KEY=

# ── n8n webhook ────────────────────────────────────────────────────────────────
# Your hosted n8n instance webhook URL (must be publicly reachable from Cloud Run)
# Example: https://your-n8n.example.com/webhook/banner-scraper
N8N_WEBHOOK_URL=https://automateoptinet.app.n8n.cloud/webhook/analyze

# ── Airtable webhook (approve flow — future) ──────────────────────────────────
# When a prompt is approved in the UI, this n8n webhook is called to save to Airtable.
# Leave blank until the Airtable workflow is ready.
AIRTABLE_WEBHOOK_URL=

# ── Google Cloud Storage (optional) ───────────────────────────────────────────
GCS_BUCKET=
GCS_PROJECT_ID=

# ── Scraper settings ──────────────────────────────────────────────────────────
MAX_TIER=3
TIER_RECHECK_DAYS=7
PAGE_TIMEOUT=60000
DEBUG_SCREENSHOTS=false
MIN_BANNER_WIDTH=500
MIN_BANNER_HEIGHT=150
