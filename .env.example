# ── Datacenter Proxy (Tier 3) ─────────────────────────────────────────────────
# Oxylabs Web Unblocker: host=unblock.oxylabs.io, protocol=https, port=60000
DC_PROXY_HOST=unblock.oxylabs.io
DC_PROXY_PORT=60000
DC_PROXY_PROTOCOL=https
DC_PROXY_USERNAME=
DC_PROXY_PASSWORD=
# Default geo (leave blank — auto-geo detection tries CA/GB/AU/SE/IN/US per site)
DC_PROXY_GEO=

# ── Residential Proxy (Tier 4) ────────────────────────────────────────────────
RES_PROXY_HOST=
RES_PROXY_PORT=
RES_PROXY_USERNAME=
RES_PROXY_PASSWORD=
RES_PROXY_GEO_COUNTRIES=US,UK,CA,AU,NZ

# ── Google Drive (direct upload — no n8n needed) ──────────────────────────────
# Service account JSON key — base64-encode your downloaded key file:
#   base64 -i your-key.json | tr -d '\n'   (Linux/Mac)
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes('key.json'))  (PowerShell)
GOOGLE_SERVICE_ACCOUNT_KEY=
# ID of your "BannerBot" root folder in Google Drive
# (copy from URL: drive.google.com/drive/folders/THIS_PART)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── WhatsApp (Meta Business Cloud API) ────────────────────────────────────────
# From Meta Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Your WhatsApp number in E.164 format: +63912345678
WHATSAPP_RECIPIENT=

# ── n8n webhook (optional legacy) ─────────────────────────────────────────────
N8N_WEBHOOK_URL=

# ── Google Cloud Storage (optional) ───────────────────────────────────────────
GCS_BUCKET=
GCS_PROJECT_ID=

# ── Scraper settings ──────────────────────────────────────────────────────────
MAX_TIER=3
TIER_RECHECK_DAYS=7
PAGE_TIMEOUT=60000
DEBUG_SCREENSHOTS=false
MIN_BANNER_WIDTH=500
MIN_BANNER_HEIGHT=150
