# ── Datacenter Proxy (Tier 3) ─────────────────────────────────────────────────
# Oxylabs Web Unblocker: host=unblock.oxylabs.io, protocol=https, port=60000
DC_PROXY_HOST=unblock.oxylabs.io
DC_PROXY_PORT=60000
DC_PROXY_PROTOCOL=https
DC_PROXY_USERNAME=
DC_PROXY_PASSWORD=
# Default geo (leave blank — auto-geo detection tries CA/GB/AU/SE/IN/US per site)
DC_PROXY_GEO=

# ── Residential Proxy (Tier 4) ────────────────────────────────────────────────
RES_PROXY_HOST=
RES_PROXY_PORT=
RES_PROXY_USERNAME=
RES_PROXY_PASSWORD=
RES_PROXY_GEO_COUNTRIES=US,UK,CA,AU,NZ

# ── Output (leave blank to save locally) ─────────────────────────────────────
N8N_WEBHOOK_URL=
# Public URL of this backend — used to build downloadable imageUrl fields in the n8n payload.
# Locally: http://localhost:3001  |  Cloud Run: https://banner-scraper-xxx.run.app
BACKEND_URL=http://localhost:3001
GCS_BUCKET=
GCS_PROJECT_ID=

# ── Scraper settings ──────────────────────────────────────────────────────────
MAX_TIER=3
TIER_RECHECK_DAYS=7
PAGE_TIMEOUT=60000
DEBUG_SCREENSHOTS=false
MIN_BANNER_WIDTH=500
MIN_BANNER_HEIGHT=150
