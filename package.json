{
  "name": "casino-banner-scraper",
  "version": "1.0.0",
  "description": "Progressive-tier casino/gaming banner scraper using Playwright",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "scrape": "ts-node src/index.ts",
    "server": "cross-env PORT=3001 ts-node src/index.ts",
    "web": "cd web && npm run dev",
    "app": "concurrently --names \"backend,frontend\" --prefix-colors \"yellow,cyan\" \"npm run server\" \"npm run web\""
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "googleapis": "^171.4.0",
    "playwright": "^1.51.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
